# Groq Cloud API key -> https://console.groq.com/keys
GROQ_API_KEY=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


# Groq Cloud model to use for all AIService calls.
# openai/gpt-oss-20b is a safe default for Groq Cloud OpenAI compatibility.
# Change this to another model slug if your key has access to a different one.
GROK_MODEL=openai/gpt-oss-20b

# Base URL for the Groq Cloud OpenAI-compatible endpoint.
# Keep the default unless your Groq Cloud team requires a custom region/pinned URL.
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Confidence threshold below which a result gets flagged for human review (0-1)
CONFIDENCE_THRESHOLD=0.7

# Max retry attempts when the model returns invalid/unparseable JSON
MAX_RETRIES=3

# Local path where ChromaDB persists its vector index
CHROMA_PERSIST_DIR=./data/chroma_db